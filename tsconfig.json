{
  "compilerOptions": {
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "outDir": "./assets/",
    "paths": {
      "/src/*": ["./src/*"]
    },
    "rootDir": "./",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src/**/*",
    "mock/**/*"
  ],
  "exclude": [
    "src/service-worker.ts"
  ]
}
